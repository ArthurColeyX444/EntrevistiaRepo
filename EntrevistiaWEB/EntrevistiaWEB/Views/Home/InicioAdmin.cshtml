@model IEnumerable<EntrevistiaWEB.Models.Cliente>
@using System.Linq

@{
    ViewBag.Title = "Panel de Administración - EntrevistIA";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var listaAdmins = ViewBag.Admins as IEnumerable<EntrevistiaWEB.Models.Administrador>;
    int totalAdmins = listaAdmins != null ? listaAdmins.Count() : 0;
    int totalClientes = Model != null ? Model.Count() : 0;
    int totalUsuarios = totalAdmins + totalClientes;

    string tabActiva = TempData["ActiveTab"] as string ?? "resumen";
}

<link rel="stylesheet" href="~/Content/inicioadmin.css?v=11.0">

<div class="admin-wrapper">
    <div class="container">

        <header style="margin-bottom: 40px;">
            <span class="badge" style="background:#e0e7ff; color:#6366f1; padding:6px 15px; border-radius:50px; font-weight:700; font-size:0.8rem;">SISTEMA DE CONTROL</span>
            <h1 style="font-size: 3rem; font-weight: 800; margin-top: 10px;">Panel de <span class="gradient-text">Administración</span></h1>
            <p style="color: #64748b; font-size: 1.1rem;">Gestión centralizada de usuarios, modelos de IA y estadísticas.</p>
        </header>

        <div class="admin-stats-grid">
            <div class="stat-card">
                <h4>Usuarios Totales</h4>
                <div class="value">@totalUsuarios</div>
                <span class="trend">↑ 12% este mes</span>
            </div>
            <div class="stat-card">
                <h4>Sesiones IA</h4>
                <div class="value">1.2k</div>
                <span class="trend">↑ 24% actividad</span>
            </div>
            <div class="stat-card">
                <h4>Score Promedio</h4>
                <div class="value">78.5%</div>
                <span class="trend" style="color:#6366f1;">Nivel: Estable</span>
            </div>
            <div class="stat-card">
                <h4>Modelos Activos</h4>
                <div class="value">89</div>
                <span class="trend">IA Generativa v4</span>
            </div>
        </div>

        <div class="tabs-nav-container">
            <button class="tab-link @(tabActiva == "resumen" ? "active" : "")" onclick="switchTab(event, 'resumen')">Resumen</button>
            <button class="tab-link @(tabActiva == "entrevistas" ? "active" : "")" onclick="switchTab(event, 'entrevistas')">Entrevistas</button>
            <button class="tab-link @(tabActiva == "preguntas" ? "active" : "")" onclick="switchTab(event, 'preguntas')">Preguntas</button>
            <button class="tab-link @(tabActiva == "clientes" ? "active" : "")" onclick="switchTab(event, 'clientes')">Usuarios</button>
        </div>

        <div id="resumen" class="tab-pane @(tabActiva == "resumen" ? "active" : "")">
            <div class="content-grid">
                <div class="glass-card">
                    <div class="card-head">
                        <div>
                            <h3>Clientes Recientes</h3>
                            <p>Últimos registros vinculados</p>
                        </div>
                    </div>
                    <div class="modern-list">
                        @if (Model != null && Model.Any())
                        {
                            foreach (var cliente in Model.Take(3))
                            {
                                <div class="modern-item">
                                    <div class="item-info">
                                        <strong>@cliente.nombresCliente</strong>
                                        <span>@cliente.correoCliente</span>
                                    </div>
                                    <div class="item-side">
                                        <span class="badge-pill">Cliente</span>
                                        <span style="display:block; font-size:0.7rem; color:#94a3b8; margin-top:5px;">
                                            ID: @(cliente.idCliente != null && cliente.idCliente.Length > 5 ? cliente.idCliente.Substring(0, 5) + "..." : cliente.idCliente)
                                        </span>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <p style="color: #64748b; text-align: center; font-size: 0.9rem;">No hay clientes registrados.</p>
                        }
                    </div>
                </div>

                <div class="glass-card">
                    <div class="card-head">
                        <div>
                            <h3>Entrevistas Populares</h3>
                            <p>Más utilizadas por usuarios</p>
                        </div>
                    </div>
                    <div class="modern-list">
                        <div class="modern-item">
                            <div class="item-info">
                                <strong>Frontend Developer React</strong>
                                <span>Desarrollo Web</span>
                            </div>
                            <div class="item-side">
                                <span class="score-text">85%</span>
                                <span style="font-size:0.7rem; color:#94a3b8;">45 Sesiones</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div id="clientes" class="tab-pane @(tabActiva == "clientes" ? "active" : "")">
            <div class="search-section">
                <div class="search-header">
                    <div class="search-title">
                        <div class="search-icon-box">🔍</div>
                        <div>
                            <h3 style="font-size:1.1rem; font-weight:800; color:#0f172a;">Búsqueda Avanzada de Usuarios</h3>
                            <p style="font-size:0.85rem; color:#64748b;">Encuentra y filtra usuarios de manera eficiente</p>
                        </div>
                    </div>
                </div>

                <div class="search-input-wrapper">
                    <input type="text" id="searchInput" onkeyup="filtrarClientes()" placeholder="Buscar por nombre, email o rol..." />
                </div>

                <div class="filter-pills">
                    <span>Filtros rápidos:</span>
                    <button class="f-pill active" onclick="aplicarFiltro(this, 'todos')">👥 Todos</button>
                    <button class="f-pill" onclick="aplicarFiltro(this, 'estudiante')">🎓 Estudiantes</button>
                    <button class="f-pill" onclick="aplicarFiltro(this, 'admin')">⚙️ Admins</button>

                    <span id="contadorResultados" style="margin-left:auto; background:#f1f5f9; padding:4px 10px; border-radius:10px; font-size:0.75rem; font-weight:700;">
                        @totalUsuarios resultados
                    </span>
                </div>
            </div>

            <div class="client-mini-stats">
                <div class="c-stat-card border-blue">
                    <div class="c-stat-info">
                        <span>Total Usuarios</span>
                        <strong>@totalUsuarios</strong>
                    </div>
                    <div style="background:#eff6ff; padding:10px; border-radius:10px; color:#3b82f6;">👥</div>
                </div>
                <div class="c-stat-card border-green">
                    <div class="c-stat-info">
                        <span>Activos</span>
                        <strong>@totalUsuarios</strong>
                    </div>
                    <div style="background:#f0fdf4; padding:10px; border-radius:10px; color:#10b981;">📈</div>
                </div>
                <div class="c-stat-card border-purple">
                    <div class="c-stat-info">
                        <span>Estudiantes</span>
                        <strong>@totalClientes</strong>
                    </div>
                    <div style="background:#faf5ff; padding:10px; border-radius:10px; color:#a855f7;">🎯</div>
                </div>
                <div class="c-stat-card border-orange">
                    <div class="c-stat-info">
                        <span>Administradores</span>
                        <strong>@totalAdmins</strong>
                    </div>
                    <div style="background:#fff7ed; padding:10px; border-radius:10px; color:#f97316;">⚙️</div>
                </div>
            </div>

            <div class="client-list-container">
                <div style="margin-bottom: 20px;">
                    <h3 style="font-size:1.1rem; color:#0f172a;">Directorio de Usuarios</h3>
                    <p style="font-size:0.85rem; color:#64748b;">Gestiona todos los perfiles registrados en la plataforma</p>
                </div>

                @if (listaAdmins != null && listaAdmins.Any())
                {
                    foreach (var admin in listaAdmins)
                    {
                        <div class="client-row">
                            <div class="c-main">
                                <div class="c-avatar" style="background: linear-gradient(135deg, #f97316, #ea580c);">
                                    @(admin.nombreAdmin != null && admin.nombreAdmin.Length >= 2 ? admin.nombreAdmin.Substring(0, 2).ToUpper() : "AD")
                                </div>
                                <div class="c-details">
                                    <strong>
                                        @admin.nombreAdmin
                                        <span class="badge-tag active">Activo</span>
                                        <span class="badge-tag" style="background:#fff7ed; color:#c2410c;">Admin</span>
                                    </strong>
                                    <div class="contact-info">
                                        <span>📧 @admin.correoAdmin</span>
                                        <span>ID: @admin.idAdmin</span>
                                    </div>
                                </div>
                            </div>
                            <div class="c-metrics">
                                <span style="font-size: 0.8rem; color: #f97316; font-weight: 700;">Súper Usuario (Acceso Total)</span>
                            </div>
                            <div class="c-actions">
                                <button title="Protegido" style="cursor:not-allowed; opacity:0.3;">🔒</button>
                            </div>
                        </div>
                    }
                }

                @if (Model != null && Model.Any())
                {
                    foreach (var cliente in Model)
                    {
                        <div class="client-row">
                            <div class="c-main">
                                <div class="c-avatar">
                                    @(cliente.nombresCliente != null && cliente.nombresCliente.Length >= 2 ? cliente.nombresCliente.Substring(0, 2).ToUpper() : "UD")
                                </div>
                                <div class="c-details">
                                    <strong>
                                        @cliente.nombresCliente
                                        <span class="badge-tag active">Activo</span>
                                        <span class="badge-tag student">Estudiante</span>
                                    </strong>
                                    <div class="contact-info">
                                        <span>📧 @cliente.correoCliente</span>
                                        <span>📞 @(cliente.telefonoCliente ?? "Sin teléfono")</span>
                                    </div>
                                </div>
                            </div>
                            <div class="c-metrics">
                                <div class="metric-box blue"><small>Entrevistas</small><span>12</span></div>
                                <div class="metric-box green"><small>Score</small><span>88%</span></div>
                                <div class="metric-box purple"><small>Tiempo</small><span>6h</span></div>
                            </div>
                            <div class="c-actions">
                                <button title="Ver detalles" onclick="abrirModalDetalles('@cliente.nombresCliente', '@cliente.correoCliente', '@(cliente.telefonoCliente ?? "")', '@cliente.edadCliente')">👁️</button>
                                <button title="Editar" onclick="abrirModal('@cliente.idCliente', '@cliente.nombresCliente', '@cliente.correoCliente', '@(cliente.telefonoCliente ?? "")', '@(cliente.edadCliente.ToString() ?? "")')">✏️</button>
                                <form action="@Url.Action("EliminarCliente", "Home")" method="post" style="display:inline;" onsubmit="return confirm('¿Seguro que deseas eliminar a este estudiante? Esta acción no se puede deshacer.');">
                                    <input type="hidden" name="idCliente" value="@cliente.idCliente" />
                                    <button type="submit" title="Eliminar" style="color:#e11d48;">🗑️</button>
                                </form>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>

        <div id="entrevistas" class="tab-pane @(tabActiva == "entrevistas" ? "active" : "")">
            @{
                var listaEntrevistas = ViewBag.Entrevistas as IEnumerable<EntrevistiaWEB.Models.Entrevista>;
            }

            <div class="card-head" style="margin-bottom: 25px; display: flex; justify-content: space-between; align-items: center;">
                <div>
                    <h3 style="font-size:1.3rem; font-weight: 800; color:#0f172a;">Gestión de Entrevistas</h3>
                </div>
                <button class="btn-primary" style="background: #4f46e5; border-radius: 10px; padding: 10px 20px; color: white; border: none; font-weight: 700; cursor: pointer;" onclick="document.getElementById('modalEntrevista').style.display='flex'">
                    + Nueva Entrevista
                </button>
            </div>

            <div class="client-list-container">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
                    <span style="font-weight: 700; color: #64748b;">
                        Lista de Entrevistas
                        <span style="background:#f1f5f9; padding:2px 8px; border-radius:6px; font-size:0.75rem; margin-left:5px;">@(listaEntrevistas != null ? listaEntrevistas.Count() : 0)</span>
                    </span>
                    <div class="search-input-wrapper" style="width: 300px; margin-bottom: 0;">
                        <input type="text" placeholder="🔍 Buscar entrevistas..." style="padding: 10px 15px; border-radius: 10px; border: 1px solid #e2e8f0; width: 100%; font-size: 0.85rem; background: #f8fafc;">
                    </div>
                </div>

                @if (listaEntrevistas != null && listaEntrevistas.Any())
                {
                    foreach (var entrevista in listaEntrevistas)
                    {
                        <div class="client-row" style="align-items: flex-start;">
                            <div class="c-main" style="flex: 3;">
                                <div class="c-details">
                                    <strong style="font-size: 1.1rem; color: #0f172a; margin-bottom: 4px; display: block;">@entrevista.tituloEntrevista</strong>
                                    <div style="display: flex; gap: 10px; align-items: center;">
                                        <span style="color: #64748b; font-size: 0.85rem; font-weight:600;">@entrevista.categoria</span>
                                        <span style="background: #e0e7ff; color: #4f46e5; font-size: 0.65rem; padding: 3px 8px; border-radius: 6px; font-weight: 800; text-transform: uppercase;">@entrevista.nivel</span>
                                    </div>
                                    <div style="display: flex; gap: 20px; margin-top: 15px; font-size: 0.8rem; color: #94a3b8; font-weight: 600;">
                                        <span>⏱️ @entrevista.duracion min</span>
                                        <span>🗣️ @entrevista.modalidad</span>
                                        <span>🏷️ @entrevista.tipo</span>
                                    </div>
                                </div>
                            </div>
                            <div class="c-actions" style="margin-top: 5px;">
                                <button title="Ver detalles">👁️</button>
                                <button title="Editar">✏️</button>
                                <button title="Eliminar" style="color:#e11d48;">🗑️</button>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="empty-state-box" style="margin-top: 20px; width: 100%;">
                        <div class="empty-state-icon">📂</div>
                        <div class="empty-state-title">No hay entrevistas creadas</div>
                        <div class="empty-state-desc">Haz clic en "+ Nueva Entrevista" para comenzar a configurar tu catálogo.</div>
                    </div>
                }
            </div>
        </div>

        <div id="preguntas" class="tab-pane @(tabActiva == "preguntas" ? "active" : "")">
            @{
                var listaPreguntas = ViewBag.Preguntas as IEnumerable<EntrevistiaWEB.Models.Pregunta>;
            }

            <div class="card-head" style="margin-bottom: 25px; display: flex; justify-content: space-between; align-items: center;">
                <div>
                    <h3 style="font-size:1.3rem; font-weight: 800; color:#0f172a;">Banco de Preguntas</h3>
                    <p style="color: #64748b; font-size: 0.9rem; margin-top: 5px;">Gestiona el catálogo central de preguntas para las entrevistas.</p>
                </div>
                <button type="button" class="btn-primary" style="background: #10b981; border-radius: 10px; padding: 10px 20px; color: white; border: none; font-weight: 700; cursor: pointer;" onclick="abrirModalPregunta(event)">
                    + Nueva Pregunta
                </button>
            </div>

            <div class="client-list-container">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
                    <span style="font-weight: 700; color: #64748b;">
                        Catálogo de Preguntas
                        <span style="background:#f1f5f9; padding:2px 8px; border-radius:6px; font-size:0.75rem; margin-left:5px;">@(listaPreguntas != null ? listaPreguntas.Count() : 0)</span>
                    </span>
                    <div class="search-input-wrapper" style="width: 300px; margin-bottom: 0;">
                        <input type="text" placeholder="🔍 Buscar preguntas..." style="padding: 10px 15px; border-radius: 10px; border: 1px solid #e2e8f0; width: 100%; font-size: 0.85rem; background: #f8fafc;">
                    </div>
                </div>

                @if (listaPreguntas != null && listaPreguntas.Any())
                {
                    foreach (var pregunta in listaPreguntas)
                    {
                        <div class="client-row" style="align-items: flex-start; padding: 15px; border-bottom: 1px solid #f1f5f9;">
                            <div class="c-main" style="flex: 3;">
                                <div class="c-details">
                                    <strong style="font-size: 1.05rem; color: #0f172a; margin-bottom: 8px; display: block;">@pregunta.textoPregunta</strong>
                                    <div style="display: flex; gap: 10px; align-items: center; margin-bottom: 10px;">
                                        <span style="background: #f1f5f9; color: #475569; font-size: 0.7rem; padding: 4px 8px; border-radius: 6px; font-weight: 700; text-transform: uppercase;">@pregunta.categoria</span>
                                        <span style="background: #fce7f3; color: #be185d; font-size: 0.7rem; padding: 4px 8px; border-radius: 6px; font-weight: 700; text-transform: uppercase;">@pregunta.tipo</span>
                                        <span style="color: #64748b; font-size: 0.8rem; font-weight: 600;">⏱️ @pregunta.tiempoEstimado min</span>
                                    </div>
                                    <div style="background: #f8fafc; padding: 10px; border-radius: 8px; font-size: 0.85rem; color: #475569; border-left: 3px solid #4f46e5;">
                                        <strong>Criterio IA:</strong> @(string.IsNullOrEmpty(pregunta.criteriosEvaluacion) ? "Sin criterio específico definido." : pregunta.criteriosEvaluacion)
                                    </div>
                                </div>
                            </div>
                            <div class="c-actions" style="margin-top: 5px;">
                                <button title="Editar">✏️</button>
                                <button title="Eliminar" style="color:#e11d48;">🗑️</button>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="empty-state-box" style="margin-top: 20px; width: 100%;">
                        <div class="empty-state-icon">📚</div>
                        <div class="empty-state-title">Banco de preguntas vacío</div>
                        <div class="empty-state-desc">Haz clic en "+ Nueva Pregunta" para empezar a construir tu repositorio de evaluaciones.</div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<div id="modalEditar" class="modal-overlay" style="display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0; justify-content: center; align-items: center; z-index: 9999; background: rgba(0,0,0,0.5);">
    <div class="modal-content new-modal" style="background: white; padding: 30px; border-radius: 15px; max-width: 500px; width: 90%; position: relative;">
        <button type="button" class="modal-close-btn" onclick="cerrarModal()" style="position: absolute; right: 15px; top: 15px; border: none; background: none; font-size: 1.2rem; cursor: pointer;">✕</button>
        <h3>📝 Editar Cliente</h3>
        <p class="subtitle">Modifica la información del estudiante</p>

        @using (Html.BeginForm("EditarCliente", "Home", FormMethod.Post))
        {
            <input type="hidden" id="editId" name="idCliente" />

            <div class="modal-grid">
                <div class="new-input-group full-w">
                    <label>Nombre Completo</label>
                    <input type="text" id="editNombre" name="nombresCliente" required style="width: 100%; padding: 10px; border-radius: 8px; border: 1px solid #ccc;" />
                </div>
                <div class="new-input-group full-w">
                    <label>Correo Electrónico</label>
                    <input type="email" id="editCorreo" name="correoCliente" required style="width: 100%; padding: 10px; border-radius: 8px; border: 1px solid #ccc;" />
                </div>
                <div class="new-input-group">
                    <label>Teléfono</label>
                    <input type="tel" id="editTelefono" name="telefonoCliente" style="width: 100%; padding: 10px; border-radius: 8px; border: 1px solid #ccc;" />
                </div>
                <div class="new-input-group">
                    <label>Edad</label>
                    <input type="number" id="editEdad" name="edadCliente" style="width: 100%; padding: 10px; border-radius: 8px; border: 1px solid #ccc;" />
                </div>
            </div>

            <div class="modal-divider" style="margin: 20px 0; border-bottom: 1px solid #eee; padding-bottom: 10px;">🔒 Cambiar Contraseña</div>

            <div class="new-input-group full-w" style="margin-bottom:15px;">
                <label>Nueva Contraseña</label>
                <input type="password" name="nuevaContraseña" placeholder="Déjalo en blanco si no deseas cambiarla" style="width: 100%; padding: 10px; border-radius: 8px; border: 1px solid #ccc;" />
            </div>

            <div class="new-modal-actions" style="display: flex; gap: 10px; justify-content: flex-end; margin-top: 20px;">
                <button type="button" class="btn-white-outline" onclick="cerrarModal()" style="padding: 10px 20px; border-radius: 8px; border: 1px solid #ccc; cursor: pointer;">Cancelar</button>
                <button type="submit" class="btn-black-solid" style="padding: 10px 20px; border-radius: 8px; background: black; color: white; border: none; cursor: pointer;">Guardar Cambios</button>
            </div>
        }
    </div>
</div>

<div id="modalEntrevista" class="modal-overlay" style="display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0; justify-content: center; align-items: center; z-index: 9999; background: rgba(0,0,0,0.5);">
    <div class="modal-content new-modal" style="max-width: 550px; background: white; padding: 30px; border-radius: 15px; width: 90%; position: relative;">
        <button type="button" class="modal-close-btn" onclick="cerrarModalEntrevista()" style="position: absolute; right: 15px; top: 15px; border: none; background: none; font-size: 1.2rem; cursor: pointer;">✕</button>

        <h3><span style="color:#4f46e5; margin-right:5px;">+</span> Crear Nueva Entrevista</h3>
        <p class="subtitle" style="margin-bottom: 25px;">Configura los detalles y asigna preguntas del banco</p>

        @using (Html.BeginForm("CrearEntrevista", "Home", FormMethod.Post))
        {
            <div style="color: #4f46e5; font-weight: 800; font-size: 0.95rem; margin-bottom: 15px;">Información Básica</div>

            <div class="new-input-group full-w" style="margin-bottom: 15px;">
                <label style="font-weight: 600;">Título de la Entrevista</label>
                <input type="text"
                       name="tituloEntrevista"
                       placeholder="Ej: Entrevista Frontend React"
                       pattern="[A-Za-zÁÉÍÓÚáéíóúñÑ\s]+"
                       title="Solo se permiten letras"
                       oninput="this.value = this.value.replace(/[^A-Za-zÁÉÍÓÚáéíóúñÑ\s]/g,'')"
                       required
                       style="width: 100%; padding: 10px; border-radius: 8px; border: 1px solid #ccc;">
            </div>

            <div class="new-input-group full-w" style="margin-bottom: 15px;">
                <label style="font-weight: 600;">Descripción</label>
                <textarea name="descripcion"
                          placeholder="Breve descripción de la entrevista"
                          oninput="this.value = this.value.replace(/[^A-Za-zÁÉÍÓÚáéíóúñÑ\s]/g,'')"
                          style="width: 100%; padding: 10px; border-radius: 8px; border: 1px solid #ccc;"></textarea>
            </div>

            <div class="modal-grid" style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px; margin-bottom: 15px;">
                <div class="new-input-group">
                    <label style="font-weight: 600;">Categoría</label>
                    <select name="categoria" style="width: 100%; padding: 10px; border-radius: 8px; border: 1px solid #ccc;">
                        <option value="Desarrollo Web">Desarrollo Web</option>
                        <option value="Recursos Humanos">Recursos Humanos</option>
                        <option value="Ventas">Ventas</option>
                        <option value="General">General</option>
                    </select>
                </div>
                <div class="new-input-group">
                    <label style="font-weight: 600;">Tipo</label>
                    <select name="tipo" style="width: 100%; padding: 10px; border-radius: 8px; border: 1px solid #ccc;">
                        <option value="Técnica">Técnica</option>
                        <option value="Habilidades Blandas">Habilidades Blandas</option>
                        <option value="Psicométrica">Psicométrica</option>
                    </select>
                </div>
                <div class="new-input-group">
                    <label style="font-weight: 600;">Nivel</label>
                    <select name="nivel" style="width: 100%; padding: 10px; border-radius: 8px; border: 1px solid #ccc;">
                        <option value="Junior">Junior</option>
                        <option value="Semi-Senior">Semi-Senior</option>
                        <option value="Senior">Senior</option>
                    </select>
                </div>
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px;">
                    <div class="new-input-group">
                        <label style="font-weight: 600;">Modalidad</label>
                        <select name="modalidad" style="width: 100%; padding: 10px; border-radius: 8px; border: 1px solid #ccc;"><option value="Texto">Texto</option><option value="Voz">Voz</option></select>
                    </div>
                    <div class="new-input-group">
                        <label>Duración <span style="font-weight:normal;color:#94a3b8;">(min)</span></label>
                        <input type="number"
                               name="duracion"
                               value="5"
                               min="5"
                               max="120"
                               step="5"
                               onkeydown="return false"
                               required>
                    </div>
                </div>
            </div>

            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px; margin-top: 20px;">
                <div style="color: #4f46e5; font-weight: 800; font-size: 0.95rem;">Selecciona Preguntas del Banco</div>
                <button type="button" onclick="abrirModalPreguntaDesdeEntrevista()" style="background: #10b981; border-radius: 8px; padding: 6px 12px; font-size: 0.75rem; color: white; border: none; font-weight: 700; cursor: pointer;">
                    + Crear y Añadir
                </button>
            </div>

            <input type="text" id="filtroPreguntas" placeholder="🔍 Buscar pregunta por texto o categoría..." onkeyup="filtrarListaPreguntas()" style="width: 100%; padding: 8px 12px; margin-bottom: 10px; border-radius: 8px; border: 1px solid #ccc; font-size: 0.85rem;">

            <div id="listaPreguntasContainer" style="max-height: 150px; overflow-y: auto; border: 1px solid #ccc; border-radius: 8px; padding: 10px; margin-bottom: 20px; background: #f8fafc;">
                @{
                    var listaFormulario = ViewBag.Preguntas as IEnumerable<EntrevistiaWEB.Models.Pregunta>;
                }

                @if (listaFormulario != null && listaFormulario.Any())
                {
                    foreach (var preg in listaFormulario)
                    {
                        <label style="display: flex; align-items: center; gap: 10px; padding: 8px 5px; border-bottom: 1px solid #e2e8f0; cursor: pointer;">
                            <input type="checkbox" name="idPreguntasSeleccionadas" value="@preg.idPregunta" style="width: 16px; height: 16px;" />
                            <span style="font-size: 0.85rem; color: #0f172a;"><strong>[@preg.categoria]</strong> @preg.textoPregunta</span>
                        </label>
                    }
                }
                else
                {
                    <p style="font-size: 0.85rem; color: #64748b; text-align: center; margin: 10px 0;">No hay preguntas en el banco. Usa el botón verde para crear una.</p>
                }
            </div>

            <div class="new-modal-actions" style="display: flex; justify-content: flex-end; gap: 10px;">
                <button type="button" class="btn-white-outline" onclick="cerrarModalEntrevista()" style="padding: 10px 20px; border-radius: 8px; border: 1px solid #ccc; cursor: pointer;">Cancelar</button>
                <button type="submit" class="btn-black-solid" style="background: #4f46e5; color: white; border: none; padding: 10px 20px; border-radius: 8px; cursor: pointer; font-weight: bold;">+ Crear Entrevista</button>
            </div>
        }
    </div>
</div>

<div id="modalDetalles" class="modal-overlay" style="display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0; justify-content: center; align-items: center; z-index: 9999; background: rgba(0,0,0,0.5);">
    <div class="modal-content new-modal" style="max-width: 500px; background: white; padding: 40px; border-radius: 15px; position: relative; width: 90%;">
        <button type="button" class="modal-close-btn" onclick="cerrarModalDetalles()" style="position: absolute; right: 15px; top: 15px; border: none; background: none; font-size: 1.2rem; cursor: pointer;">✕</button>

        <h3 style="font-size: 1.4rem; margin-bottom: 5px;">Detalles del Cliente</h3>
        <p class="subtitle" style="margin-bottom: 30px;">Información completa del cliente seleccionado</p>

        <div class="modal-details-header" style="display: flex; gap: 20px; align-items: center; margin-bottom: 20px;">
            <div class="md-avatar" id="detAvatar" style="background: #e2e8f0; width: 60px; height: 60px; border-radius: 50%; display: flex; justify-content: center; align-items: center; font-size: 1.5rem; font-weight: bold;">MS</div>
            <div class="md-name-section">
                <h2 id="detNombre" style="margin: 0; font-size: 1.2rem;">María Silva</h2>
                <p id="detCorreo" style="margin: 0; color: #64748b;">maria.silva@email.com</p>
                <span class="badge-active-lg" style="background: #dcfce7; color: #166534; padding: 2px 8px; border-radius: 10px; font-size: 0.8rem;">Activo</span>
            </div>
        </div>

        <div class="md-grid" style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
            <div>
                <h4 class="md-section-title">Información Personal</h4>
                <ul class="md-info-list" style="list-style: none; padding: 0; line-height: 1.8;">
                    <li><i>👤</i> <span id="detUsername">@("@")maria_silva</span></li>
                    <li><i>📞</i> <span id="detTelefono">+57 300 345 6789</span></li>
                    <li><i>📅</i> <span id="detEdad">23 años</span></li>
                </ul>
            </div>
            <div>
                <h4 class="md-section-title">Estadísticas</h4>
                <ul class="md-stats-list" style="list-style: none; padding: 0; line-height: 1.8;">
                    <li><span>Entrevistas:</span> <strong id="detStats1">15</strong></li>
                    <li><span>Score Promedio:</span> <strong id="detStats2">92%</strong></li>
                    <li><span>Tiempo Total:</span> <strong id="detStats3">8h</strong></li>
                </ul>
            </div>
        </div>
    </div>
</div>

<div id="modalPregunta" class="modal-overlay" style="display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0; justify-content: center; align-items: center; z-index: 999999; background: rgba(0,0,0,0.6);">
    <div class="modal-content new-modal" style="max-width: 600px; width: 90%; background: white; border-radius: 15px; padding: 30px; position: relative;">
        <button type="button" class="modal-close-btn" onclick="cerrarModalPregunta()" style="position: absolute; right: 15px; top: 15px; border: none; background: none; font-size: 1.5rem; cursor: pointer; color: #64748b;">✕</button>

        <h3 style="margin-top:0;"><span style="color:#10b981; margin-right:5px;">+</span> Añadir al Banco de Preguntas</h3>
        <p class="subtitle" style="margin-bottom: 25px; color: #64748b;">Crea una nueva pregunta para usar en futuras entrevistas.</p>

        <form id="formPregunta" action="@Url.Action("CrearPregunta", "Home")" method="post">
            <div style="color: #10b981; font-weight: 800; font-size: 0.95rem; margin-bottom: 15px;">Detalles de la Pregunta</div>

            <div class="new-input-group full-w" style="margin-bottom: 15px;">
                <label style="display:block; margin-bottom:5px; font-weight:600;">Texto de la Pregunta</label>
                <textarea name="textoPregunta" placeholder="Ej: Describe una situación donde tuviste que liderar un equipo en crisis." required style="width: 100%; min-height: 80px; padding: 10px; border-radius: 8px; border: 1px solid #ccc; font-family: inherit;"></textarea>
            </div>

            <div class="modal-grid" style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px; margin-bottom: 15px;">
                <div class="new-input-group">
                    <label style="display:block; margin-bottom:5px; font-weight:600;">Categoría</label>
                    <select name="categoria" required style="width: 100%; padding: 10px; border-radius: 8px; border: 1px solid #ccc;">
                        <option value="">Selecciona...</option>
                        <option value="Desarrollo Web">Desarrollo Web</option>
                        <option value="Recursos Humanos">Recursos Humanos</option>
                        <option value="Ventas">Ventas</option>
                        <option value="Liderazgo">Liderazgo</option>
                        <option value="General">General</option>
                    </select>
                </div>
                <div class="new-input-group">
                    <label style="display:block; margin-bottom:5px; font-weight:600;">Tipo de Pregunta</label>
                    <select name="tipo" required style="width: 100%; padding: 10px; border-radius: 8px; border: 1px solid #ccc;">
                        <option value="">Selecciona...</option>
                        <option value="Técnica">Técnica</option>
                        <option value="Comportamental">Comportamental</option>
                        <option value="Lógica">Lógica</option>
                        <option value="Situacional">Situacional</option>
                    </select>
                </div>
            </div>

            <div class="new-input-group full-w" style="margin-bottom: 15px;">
                <label style="display:block; margin-bottom:5px; font-weight:600;">Criterios de Evaluación para la IA (Opcional)</label>
                <textarea name="criteriosEvaluacion" placeholder="Ej: Otorga 10 puntos si menciona el método STAR." style="width: 100%; min-height: 80px; padding: 10px; border-radius: 8px; border: 1px solid #ccc; background: #f8fafc; font-family: inherit;"></textarea>
            </div>

            <div class="new-input-group" style="width: 50%; margin-bottom: 25px;">
                <label style="display:block; margin-bottom:5px; font-weight:600;">Tiempo Estimado (minutos)</label>
                <input type="number" name="tiempoEstimado" value="5" min="1" max="60" required style="width: 100%; padding: 10px; border-radius: 8px; border: 1px solid #ccc;">
            </div>

            <div class="new-modal-actions" style="display: flex; justify-content: flex-end; gap: 10px;">
                <button type="button" class="btn-white-outline" onclick="cerrarModalPregunta()" style="padding: 10px 20px; border-radius: 8px; border: 1px solid #ccc; cursor: pointer; background: white;">Cancelar</button>
                <button type="submit" class="btn-black-solid" style="padding: 10px 20px; border-radius: 8px; background: #10b981; color: white; border: none; cursor: pointer; font-weight: bold;">Guardar Pregunta</button>
            </div>
        </form>
    </div>
</div>

@section scripts {
    <script>
        function switchTab(evt, tabId) {
            const panes = document.querySelectorAll('.tab-pane');
            panes.forEach(p => p.classList.remove('active'));

            const links = document.querySelectorAll('.tab-link');
            links.forEach(l => l.classList.remove('active'));

            document.getElementById(tabId).classList.add('active');
            evt.currentTarget.classList.add('active');
        }

        function abrirModal(id, nombre, correo, telefono, edad) {
            document.getElementById('editId').value = id;
            document.getElementById('editNombre').value = nombre;
            document.getElementById('editCorreo').value = correo;
            document.getElementById('editTelefono').value = telefono;
            document.getElementById('editEdad').value = edad;
            document.getElementById('modalEditar').style.display = 'flex';
        }
        function cerrarModal() { document.getElementById('modalEditar').style.display = 'none'; }

        function abrirModalEntrevista() { document.getElementById('modalEntrevista').style.display = 'flex'; }
        function cerrarModalEntrevista() { document.getElementById('modalEntrevista').style.display = 'none'; }

        function abrirModalDetalles(nombre, correo, telefono, edad) {
            document.getElementById('detNombre').innerText = nombre;
            document.getElementById('detCorreo').innerText = correo;

            let iniciales = "UD";
            if (nombre && nombre.length >= 2) {
                let partes = nombre.trim().split(' ');
                if (partes.length >= 2) { iniciales = partes[0].charAt(0) + partes[1].charAt(0); }
                else { iniciales = nombre.substring(0, 2); }
            }
            document.getElementById('detAvatar').innerText = iniciales.toUpperCase();

            let arroba = String.fromCharCode(64);
            document.getElementById('detUsername').innerText = arroba + correo.split(arroba)[0].toLowerCase();
            document.getElementById('detTelefono').innerText = telefono && telefono.trim() !== '' ? telefono : 'No registrado';
            document.getElementById('detEdad').innerText = edad && edad !== '0' && edad.trim() !== '' ? edad + ' años' : 'No registrada';
            document.getElementById('modalDetalles').style.display = 'flex';
        }
        function cerrarModalDetalles() { document.getElementById('modalDetalles').style.display = 'none'; }

        // ==========================================
        // MAGIA DEL MODAL DE PREGUNTAS Y AJAX
        // ==========================================
        let creandoDesdeEntrevista = false;

        function abrirModalPreguntaDesdeEntrevista() {
            creandoDesdeEntrevista = true;
            document.getElementById('modalPregunta').style.display = 'flex';
        }

        function abrirModalPregunta(e) {
            if(e) e.preventDefault();
            creandoDesdeEntrevista = false; // Se abrió desde la pestaña normal
            document.getElementById('modalPregunta').style.display = 'flex';
        }

        function cerrarModalPregunta() {
            document.getElementById('modalPregunta').style.display = 'none';
        }

        // Interceptamos el botón guardar para usar AJAX si venimos de la Entrevista
        document.getElementById("formPregunta").addEventListener("submit", function(e) {
            if (creandoDesdeEntrevista) {
                e.preventDefault(); // Detiene la recarga de página normal

                let formData = new FormData(this);

                // Llamamos al método secreto del controlador
                fetch('@Url.Action("CrearPreguntaAjax", "Home")', {
                    method: 'POST',
                    body: formData
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        let container = document.getElementById("listaPreguntasContainer");

                        // Si estaba vacío, borramos el mensaje gris
                        let emptyMsg = container.querySelector("p");
                        if (emptyMsg) emptyMsg.remove();

                        // Creamos el nuevo checkbox en vivo y lo marcamos
                        let nuevoLabel = document.createElement("label");
                        nuevoLabel.style.cssText = "display: flex; align-items: center; gap: 10px; padding: 8px 5px; border-bottom: 1px solid #e2e8f0; cursor: pointer; background: #ecfdf5;";
                        nuevoLabel.innerHTML = `<input type="checkbox" name="idPreguntasSeleccionadas" value="${data.idPregunta}" checked style="width: 16px; height: 16px;" />
                                                <span style="font-size: 0.85rem; color: #0f172a;"><strong>[${data.categoria}]</strong> ${data.texto}</span>`;

                        container.prepend(nuevoLabel); // Lo pone de primero en la lista

                        this.reset(); // Limpia el formulario
                        cerrarModalPregunta(); // Cierra el modal verde
                    } else {
                        alert("Error al guardar: " + data.message);
                    }
                })
                .catch(error => console.error("Error:", error));
            }
            // Si creandoDesdeEntrevista es false, el formulario se envía normal (recarga la página).
        });

        // ==========================================
        // BUSCADOR EN TIEMPO REAL
        // ==========================================
        function filtrarListaPreguntas() {
            let filtro = document.getElementById("filtroPreguntas").value.toLowerCase();
            let labels = document.querySelectorAll("#listaPreguntasContainer label");

            labels.forEach(label => {
                let texto = label.innerText.toLowerCase();
                if (texto.includes(filtro)) {
                    label.style.display = "flex";
                } else {
                    label.style.display = "none";
                }
            });
        }

        window.onclick = function (event) {
            if (event.target == document.getElementById('modalEditar')) cerrarModal();
            if (event.target == document.getElementById('modalEntrevista')) cerrarModalEntrevista();
            if (event.target == document.getElementById('modalDetalles')) cerrarModalDetalles();
            if (event.target == document.getElementById('modalPregunta')) cerrarModalPregunta();
        }

        let filtroActual = 'todos';
        function aplicarFiltro(boton, tipoFiltro) {
            document.querySelectorAll('.f-pill').forEach(btn => btn.classList.remove('active'));
            boton.classList.add('active');
            filtroActual = tipoFiltro;
            filtrarClientes();
        }
        function filtrarClientes() {
            const textoBusqueda = document.getElementById('searchInput').value.toLowerCase();
            const filas = document.querySelectorAll('.client-row');
            let contadorVisible = 0;

            filas.forEach(fila => {
                const contenidoFila = fila.innerText.toLowerCase();
                const coincideTexto = contenidoFila.includes(textoBusqueda);
                let coincideFiltro = false;

                if (filtroActual === 'todos') coincideFiltro = true;
                else if (filtroActual === 'estudiante' && contenidoFila.includes('estudiante')) coincideFiltro = true;
                else if (filtroActual === 'admin' && contenidoFila.includes('admin')) coincideFiltro = true;

                if (coincideTexto && coincideFiltro) {
                    fila.style.display = '';
                    contadorVisible++;
                } else {
                    fila.style.display = 'none';
                }
            });
            document.getElementById('contadorResultados').innerText = contadorVisible + ' resultados';
        }
    </script>
}