@{
    ViewBag.Title = "Panel de Control - EntrevistIA";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="~/Content/InicioCliente.css">

<div class="dashboard-wrapper">
    <div class="container">

        <!-- HEADER -->
        <header class="db-header">
            <div>
                <span class="user-badge">Panel de Candidato</span>
                <h1>¡Hola, <span class="gradient-text">@Session["Nombre"]</span>!</h1>
                <p>Continúa perfeccionando tu técnica. Hoy es un buen día para practicar.</p>
            </div>
        </header>

        <!-- METRICAS -->
        <div class="impact-metrics">

            <div class="metric-block">
                <span class="m-value">85<small>%</small></span>
                <span class="m-label">Puntaje Global</span>
            </div>

            <div class="metric-block">
                <span class="m-value">03</span>
                <span class="m-label">Simulaciones</span>
            </div>

            <div class="metric-block">
                <span class="m-value">95<small>m</small></span>
                <span class="m-label">Tiempo de Práctica</span>
            </div>

        </div>

        <!-- GRID PRINCIPAL -->
        <div class="db-grid">

            <!-- IZQUIERDA -->
            <main class="db-main">

                <!-- ACCIONES RAPIDAS -->
                <div class="quick-actions-card">

                    <h3>Acciones Rápidas</h3>
                    <p>Comienza una nueva entrevista o continúa con tu progreso</p>

                    <div class="quick-buttons">

                        <button class="btn-primary">
                            🔍 Buscar Entrevistas
                        </button>

                        <button class="btn-secondary">
                            🕘 Ver Historial
                        </button>

                    </div>

                </div>


                <!-- ENTREVISTAS RECOMENDADAS -->
                <div class="recommended-card">

                    <h3>Entrevistas Recomendadas</h3>
                    <p>Basado en tu perfil y rendimiento anterior</p>

                    <div class="interview-item">

                        <div>
                            <strong>Entrevista Técnica Frontend</strong>
                            <p>Preguntas sobre React, JavaScript y CSS</p>

                            <div class="tags">
                                <span class="tag blue">mid</span>
                                <span class="tag orange">technical</span>
                                <span class="tag">8 preguntas</span>
                                <span class="tag">30 min</span>
                            </div>
                        </div>

                        <button class="btn-start">▶ Iniciar</button>

                    </div>


                    <div class="interview-item">

                        <div>
                            <strong>Entrevista de RRHH</strong>
                            <p>Preguntas generales sobre experiencia laboral</p>

                            <div class="tags">
                                <span class="tag green">junior</span>
                                <span class="tag blue">hr</span>
                                <span class="tag">6 preguntas</span>
                                <span class="tag">25 min</span>
                            </div>
                        </div>

                        <button class="btn-start">▶ Iniciar</button>

                    </div>


                    <div class="interview-item">

                        <div>
                            <strong>Entrevista Comportamental</strong>
                            <p>Situaciones hipotéticas y resolución de problemas</p>

                            <div class="tags">
                                <span class="tag purple">senior</span>
                                <span class="tag pink">behavioral</span>
                                <span class="tag">10 preguntas</span>
                                <span class="tag">40 min</span>
                            </div>
                        </div>

                        <button class="btn-start">▶ Iniciar</button>

                    </div>

                </div>

            </main>


            <!-- DERECHA -->
            <aside class="db-sidebar">

                <!-- PROGRESO -->
                <div class="sidebar-card">

                    <h4>Tu Progreso</h4>

                    <div class="progress-bar">
                        <div class="progress" style="width:85%"></div>
                    </div>

                    <div class="progress-info">
                        <span>Puntaje General</span>
                        <strong>85%</strong>
                    </div>

                    <div class="progress-info">
                        <span>Entrevistas Completadas</span>
                        <strong>3 / 10</strong>
                    </div>

                    <div class="progress-info">
                        <span>Objetivo Mensual</span>
                        <strong>85%</strong>
                    </div>

                </div>


                <!-- ACTIVIDAD RECIENTE -->
                <div class="sidebar-card">

                    <h4>Actividad Reciente</h4>

                    <div class="activity-item">
                        <span class="dot blue"></span>
                        Entrevista Técnica Backend
                        <strong>85%</strong>
                    </div>

                    <div class="activity-item">
                        <span class="dot green"></span>
                        Entrevista de RRHH
                        <strong>92%</strong>
                    </div>

                    <div class="activity-item">
                        <span class="dot blue"></span>
                        Entrevista Comportamental
                        <strong>78%</strong>
                    </div>

                </div>


                <!-- TIP DEL DIA -->
                <div class="sidebar-card">

                    <h4>Tip del Día</h4>

                    <p>
                        💡 Practica la regla <strong>STAR</strong>
                        (Situación, Tarea, Acción, Resultado) para responder preguntas comportamentales de forma estructurada.
                    </p>

                </div>

            </aside>

        </div>

    </div>
</div>