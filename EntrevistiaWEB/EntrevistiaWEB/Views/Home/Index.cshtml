@{
    ViewBag.Title = "EntrevistIA - Domina tu Entrevista";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<canvas id="bg-animation" class="bg-animation-canvas"></canvas>

<header class="hero container">
    <div class="hero-text" data-aos="fade-right">
        <span class="badge">Nueva versión 2.0 disponible</span>
        <h1>Prepárate para tu <br><span class="gradient-text">entrevista ideal</span></h1>
        <p>Utilizamos IA generativa de última generación para simular entornos reales de entrevista. Practica, falla en privado y brilla en público.</p>
        <div class="hero-actions">
            <a href="@Url.Action("Login", "Home")" class="btn-primary">Comenzar Gratis</a>
            <button class="btn-video"><span>▶</span> Ver Demo</button>
        </div>
        <div class="hero-stats">
            <div><strong>10k+</strong> Usuarios</div>
            <div class="divider"></div>
            <div><strong>95%</strong> Éxito</div>
            <div class="divider"></div>
            <div><strong>24/7</strong> Soporte</div>
        </div>
    </div>
    <div class="hero-visual" data-aos="zoom-in-up">
        <div class="image-wrapper">
            <img src='@Url.Content("~/Content/Ally_inico.png")' alt="Entrevista">
            <div class="floating-card" aria-hidden="true">
                <p>Feedback IA: "Tu lenguaje corporal denota confianza"</p>
            </div>

            <!-- Overlay / demo badge (opcional, estilizado desde CSS) -->
            <div class="demo-badge" aria-hidden="true">
                <span class="dot"></span> Demo en vivo
            </div>
        </div>
    </div>
</header>

<section class="features container">
    <div class="section-header features-header" data-aos="fade-up">
        <h2>¿Por qué elegir EntrevistIA?</h2>
        <p>
            Nuestra plataforma combina tecnología de vanguardia con metodologías probadas
            para ofrecerte la mejor experiencia de preparación para entrevistas.
        </p>
    </div>

    <div class="feature-grid">
        <div class="feat-card" data-aos="fade-up" data-aos-delay="100">
            <div class="icon-box blue-grad">
                💬
            </div>
            <h3>Entrevistas Multimodales</h3>
            <p>
                Practica con texto, voz o video según tus preferencias
                y las demandas del puesto.
            </p>
        </div>

        <div class="feat-card" data-aos="fade-up" data-aos-delay="200">
            <div class="icon-box purple-grad">
                🧠
            </div>
            <h3>IA Avanzada</h3>
            <p>
                Recibe retroalimentación detallada y personalizada
                generada por inteligencia artificial.
            </p>
        </div>

        <div class="feat-card" data-aos="fade-up" data-aos-delay="300">
            <div class="icon-box pink-grad">
                🎯
            </div>
            <h3>Entrenamiento Específico</h3>
            <p>
                Filtra por área, nivel y tipo de entrevista
                para una preparación más efectiva.
            </p>
        </div>
    </div>
</section>

<link rel="stylesheet" href="~/Content/bg-animation.css" />
<script src="~/Scripts/bg-animation.js"></script>

<section class="how-it-works container">
    <div class="section-header" data-aos="fade-up">
        <h2>¿Cómo funciona?</h2>
        <p>En solo 3 pasos, estarás practicando entrevistas como un profesional.</p>
    </div>
    <div class="steps-grid">
        <div class="step-item" data-aos="fade-right" data-aos-delay="100">
            <div class="step-circle blue-grad">1</div>
            <h4>Configura tu Perfil</h4>
            <p>Crea tu cuenta y personaliza tu trayectoria profesional.</p>
        </div>
        <div class="step-item" data-aos="fade-right" data-aos-delay="200">
            <div class="step-circle purple-grad">2</div>
            <h4>Selecciona el Reto</h4>
            <p>Elige entre cientos de escenarios categorizados por industria.</p>
        </div>
        <div class="step-item" data-aos="fade-right" data-aos-delay="300">
            <div class="step-circle pink-grad">3</div>
            <h4>Practica y Mejora</h4>
            <p>Realiza la entrevista y recibe feedback instantáneo detallado.</p>
        </div>
    </div>
</section>

<section class="modes container">
    <div class="glass-container" data-aos="zoom-in">
        <div class="mode-item">
            <span class="mode-icon">⌨️</span>
            <h4>Texto</h4>
            <ul class="mode-list">
                <li>Contador de palabras</li>
                <li>Ideal para principiantes</li>
            </ul>
        </div>
        <div class="mode-item">
            <span class="mode-icon">🎙️</span>
            <h4>Voz</h4>
            <ul class="mode-list">
                <li>Análisis de tono</li>
                <li>Detector de muletillas</li>
            </ul>
        </div>
        <div class="mode-item">
            <span class="mode-icon">📸</span>
            <h4>Video</h4>
            <ul class="mode-list">
                <li>Contacto visual</li>
                <li>Presencia profesional</li>
            </ul>
        </div>
    </div>
</section>

<section class="team container">
    <div class="section-header" data-aos="fade-up">
        <h2>Nuestro Equipo</h2>
        <div class="team-grid">
            <div class="team-card" data-aos="flip-left" data-aos-delay="100">
                <div class="team-avatar blue-grad">JC</div>
                <h3>Jork Coley</h3>
                <p>Desarrollador Full-Stack</p>
            </div>
            <div class="team-card" data-aos="flip-left" data-aos-delay="200">
                <div class="team-avatar purple-grad">JM</div>
                <h3>Jesus Mejia</h3>
                <p>Desarrollador Full-Stack</p>
            </div>
            <div class="team-card" data-aos="flip-left" data-aos-delay="300">
                <div class="team-avatar pink-grad">AG</div>
                <h3>Allyson Gamarra</h3>
                <p>Desarrollador Full-Stack</p>
            </div>
        </div>
    </div>
</section>

<section class="cta-full">
    <div class="container" data-aos="zoom-out">
        <h2>¿Listo para transformar tu carrera profesional?</h2>
        <p>Únete hoy mismo a la revolución de la preparación laboral.</p>
        <a href="@Url.Action("Login", "Home")" class="btn-white">Comenzar Gratis Ahora</a>
    </div>
</section>