<!DOCTYPE html>
<html lang="es">
<style>
    /* FORZAR LA ESTRUCTURA DEL MENÚ DESPLEGABLE */
    .profile-menu-container {
        position: relative !important;
        display: inline-block;
    }

    .profile-dropdown-content {
        display: none !important; /* ESTO ES LO QUE LO OCULTA POR DEFECTO */
        position: absolute !important;
        top: 120%;
        right: 0;
        background-color: #ffffff;
        min-width: 220px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.15) !important;
        border-radius: 12px;
        border: 1px solid #e2e8f0;
        z-index: 99999 !important;
        flex-direction: column;
        padding: 8px 0;
    }

        /* ESTA CLASE LA ACTIVA EL JAVASCRIPT */
        .profile-dropdown-content.show {
            display: flex !important;
        }

    .dropdown-item {
        padding: 12px 20px;
        color: #475569;
        text-decoration: none;
        font-weight: 600;
        font-size: 0.9rem;
        display: block;
        transition: 0.2s;
    }

        .dropdown-item:hover {
            background-color: #f1f5f9;
            color: #6366f1;
        }

    .dropdown-header {
        padding: 10px 20px 15px 20px;
        background: #f8fafc;
    }
</style>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - EntrevistIA</title>

    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700;800&display=swap" rel="stylesheet">
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">

    <link rel="stylesheet" href="~/Content/style.css">

    @RenderSection("styles", required: false)
</head>
<body>

    <nav class="navbar">
        <div class="container nav-flex">
            <a href="@Url.Action("Index", "Home")" class="logo">
                <div class="logo-icon blue-grad">🧠</div>
                <span>EntrevistIA</span>
            </a>

            <div class="nav-links">
                @if (Session["Nombre"] != null)
                {
                    bool esAdmin = Session["Perfil"] != null && Session["Perfil"].ToString() == "Admin";

                    <a href="@(esAdmin ? Url.Action("InicioAdmin", "Home") : Url.Action("InicioCliente", "Home"))">Dashboard</a>

                    <div class="profile-menu-container">
                        <div class="user-nav-pill" onclick="toggleProfileMenu()">
                            <div class="nav-avatar">@Session["Nombre"].ToString().Substring(0, 2).ToUpper()</div>
                            <span class="nav-username">@Session["Nombre"]</span>
                            <span class="dropdown-arrow">▼</span>
                        </div>

                        <div id="profileDropdown" class="profile-dropdown-content">
                            <div class="dropdown-header">
                                <strong>@Session["Nombre"]</strong>
                                <span style="font-size: 0.75rem; color: #64748b; font-weight: 700;">
                                    @(esAdmin ? "ADMINISTRADOR" : "ESTUDIANTE")
                                </span>
                            </div>
                            <hr />

                            @if (esAdmin)
                            {
                               
                            }
                            else
                            {
                                <a href="@Url.Action("PerfilCliente", "Home")" class="dropdown-item">
                                    <span class="icon">👤</span> Mi Perfil
                                </a>
                            }

                            <hr />
                            <a href="@Url.Action("Logout", "Account")" class="dropdown-item logout">
                                <span class="icon">🚪</span> Cerrar Sesión
                            </a>
                        </div>
                    </div>
                }
                else
                {
                    <a href="@Url.Action("Index", "Home")">Inicio</a>
                    <a href="#">Metodología</a>
                    <a href="@Url.Action("Login", "Home")" class="btn-login">Iniciar Sesión</a>
                }
            </div>
        </div>
    </nav>

    <main>
        @RenderBody()
    </main>

    <footer class="footer">
        <div class="container footer-grid">
            <div class="footer-brand">
                <div class="logo light">EntrevistIA</div>
                <p>Potenciando carreras con IA.</p>
            </div>
            <div class="footer-copy">
                <p>&copy; @DateTime.Now.Year EntrevistIA. Desarrollado por el equipo de expertos.</p>
            </div>
        </div>
    </footer>

    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script>
        AOS.init({ duration: 1000, once: true });
    </script>
    @RenderSection("scripts", required: false)

<script>
    function toggleProfileMenu() {
        const menu = document.getElementById("profileDropdown");
        if (menu) menu.classList.toggle("show");
    }

    // Cerrar si el usuario hace clic en otro lado
    window.addEventListener('click', function(e) {
        const container = document.querySelector('.profile-menu-container');
        if (container && !container.contains(e.target)) {
            document.getElementById("profileDropdown").classList.remove("show");
        }
    });

    // Pregunta de confirmación para salir
    function confirmLogout() {
        const respuesta = confirm("¿Estás seguro de que deseas cerrar tu sesión en EntrevistIA?");
        if (respuesta) {
    
            window.location.href = "@Url.Action("Login", "Home")";
        }
    }


    function confirmLogout() {
        const respuesta = confirm("¿Estás seguro de que deseas cerrar tu sesión en EntrevistIA?");
        if (respuesta) {
    
            window.location.href = "@Url.Action("Login", "Home")";
        }
    }

    

</script>
    
</body>
</html>